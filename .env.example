# Wybierz providera: anthropic | openai
MODEL_PROVIDER=anthropic

# Klucze API - uzupełnij swój
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Modele (możesz zmieniać i porównywać koszty)
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
OPENAI_MODEL=gpt-4o-mini

# Aplikacja
APP_ENV=development
LOG_LEVEL=INFO
